/* config.h — Copy this file to config.h and fill in your values. */
/* config.h is excluded from git (.gitignore). */

#ifndef CONFIG_H
#define CONFIG_H

/* --- WiFi --- */
#define WIFI_SSID     "your_ssid"
#define WIFI_PASSWORD "your_password"

/* --- Server --- */
#define SERVER_HOST   "www.example.com"
#define SERVER_PORT   80
#define SERVER_PATH   "/accucheck2/add.php"
#define SERVER_KEY    "your_shared_secret"

/* --- I2C / INA226 --- */
#define INA226_ADDRESS  0x40
#define SHUNT_RESISTOR_MOHM  100
#define I2C_SDA  21
#define I2C_SCL  22

/* --- FET GPIO --- */
#define FET_PIN  25

/* --- Status LED (onboard blue LED on ESP32 DEVKIT V1) --- */
#define LED_PIN  2

/* --- Discharge parameters --- */
#define V_CUTOFF_MV          3000
#define MEASURE_INTERVAL_MS  10000
#define MAX_DISCHARGE_TIME_S 259200

#endif
